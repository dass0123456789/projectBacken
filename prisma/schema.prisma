generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "mysql"
url      = env("DATABASE_URL")
}

enum Role {
USER
TECHNICIAN
ADMIN
}

enum Status {
ACTIVE
INACTIVE
BANNED
}

enum Gender {
MALE
FEMALE
OTHER
}

model Users {
Users_Id Int @id @default(autoincrement())

Email    String @unique
Password String
Role   Role
Status Status @default(ACTIVE)
Created_At DateTime @default(now())
Updated_At DateTime @updatedAt
Profile Profiles?
Services Services[]
Orders   Orders[]

@@map("users")
}
model Profiles {
Profile_Id Int @id @default(autoincrement())
Users_Id Int @unique
First_Name String?
Last_Name  String?
Phone   String?
Avatar  String?
Address String?
Gender Gender?
Birth_Date DateTime?
Bio String?
Experience_Year Int?
Created_At DateTime @default(now())
Updated_At DateTime @updatedAt
User Users @relation(fields: [Users_Id],references: [Users_Id])
@@map("profiles")
}
model Services {
Service_Id Int @id @default(autoincrement())
Users_Id Int
Title String
Description String?
Price Float
Created_At DateTime @default(now())
Updated_At DateTime @updatedAt
User Users @relation(fields: [Users_Id],references: [Users_Id])
Orders Orders[]
@@map("services")
}
model Orders {
Order_Id Int @id @default(autoincrement())
Users_Id Int
Service_Id Int
Status String @default("PENDING")
Created_At DateTime @default(now())
Updated_At DateTime @updatedAt
User Users @relation(fields: [Users_Id],references: [Users_Id])
Service Services @relation(fields: [Service_Id],references: [Service_Id])
Review Reviews?
@@map("orders")
}
model Reviews {
Review_Id Int @id @default(autoincrement())
Order_Id Int @unique
Rating Int
Comment String?
Created_At DateTime @default(now())
Order Orders @relation(fields: [Order_Id],references: [Order_Id])
@@map("reviews")
}
model Chats {
Chat_Id Int @id @default(autoincrement())
Sender_Id Int
Receiver_Id Int
Message String
Created_At DateTime @default(now())
@@map("chats")
}
