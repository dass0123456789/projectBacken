generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url= env("DATABASE_URL")
}

model Users {
  Users_Id Int @id @default(autoincrement())

  Email    String @unique
  Password String

  Role   Role
  Status Status @default(ACTIVE)

  Created_At DateTime @default(now())
  Updated_At DateTime @updatedAt

  Profile Profiles?

  @@map("users")
}

model Profiles {
  Profile_Id Int @id @default(autoincrement())

  Users_Id Int @unique

  First_Name String?
  Last_Name  String?

  Phone  String?
  Avatar String?

  Gender Gender?

  Birth_Date DateTime?
  Address    String?   @db.Text

  Created_At DateTime @default(now())
  Updated_At DateTime @updatedAt

  User Users @relation(fields: [Users_Id], references: [Users_Id])

  @@map("profiles")
}

enum Role {
  USER
  TECHNICIAN
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  BANNED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
